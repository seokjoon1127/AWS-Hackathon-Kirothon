{
  "enabled": true,
  "name": "TypeScript 린트",
  "description": "TypeScript/TSX 파일이 수정되면 ESLint를 실행합니다",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint --fix ."
  }
}